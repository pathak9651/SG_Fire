# =============================================================
# SG Fire — Environment Variables Example File
# =============================================================
# PURPOSE: This file documents ALL required environment variables.
#          Copy this file to `.env` and fill in your actual values.
#          NEVER commit `.env` to version control (it's in .gitignore).
# =============================================================

# ─────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────
# PORT: The port number on which the Express server will listen.
PORT=5000

# NODE_ENV: Application environment. Options: development | production | test
NODE_ENV=development

# ─────────────────────────────────────────────
# MONGODB DATABASE
# ─────────────────────────────────────────────
# MONGO_URI: MongoDB Atlas connection string.
# Get this from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/sgfire?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# JWT (JSON Web Tokens) — Authentication
# ─────────────────────────────────────────────
# JWT_SECRET: Secret key used to sign access tokens. Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT_EXPIRE: Access token expiration time. Examples: 15m, 1h, 7d
JWT_EXPIRE=15m

# JWT_REFRESH_SECRET: Separate secret for refresh tokens (more secure).
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_too

# JWT_REFRESH_EXPIRE: Refresh token expiration. Typically longer than access token.
JWT_REFRESH_EXPIRE=7d

# ─────────────────────────────────────────────
# CLOUDINARY — Image & File Storage
# ─────────────────────────────────────────────
# Get these from: https://cloudinary.com → Dashboard
# Used for: product images, banner uploads, appointment site images
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─────────────────────────────────────────────
# RAZORPAY — Payment Gateway (India Primary)
# ─────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys for development, LIVE keys for production
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─────────────────────────────────────────────
# STRIPE — Payment Gateway (International)
# ─────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API Keys
# Use TEST keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─────────────────────────────────────────────
# EMAIL — Nodemailer SMTP Configuration
# ─────────────────────────────────────────────
# Used for: OTP verification, order confirmations, appointment reminders
# For Gmail: Enable 2FA → Generate App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=SG Fire <noreply@sgfire.com>

# ─────────────────────────────────────────────
# GOOGLE OAUTH — Social Login
# ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─────────────────────────────────────────────
# FRONTEND URL — CORS Configuration
# ─────────────────────────────────────────────
# CLIENT_URL: The URL of your Next.js frontend app.
# Used for CORS origin whitelisting and redirect URLs.
CLIENT_URL=http://localhost:3000

# ─────────────────────────────────────────────
# COOKIE CONFIGURATION
# ─────────────────────────────────────────────
# COOKIE_EXPIRE: Days until auth cookie expires. Example: 7 means 7 days.
COOKIE_EXPIRE=7

# ─────────────────────────────────────────────
# REDIS (Optional — Caching)
# ─────────────────────────────────────────────
# Used for: session caching, rate limiting store, product cache
# Get from: https://redis.com/try-free/ or use local Redis
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# COMPANY INFO (Used in email templates)
# ─────────────────────────────────────────────
COMPANY_NAME=SG Fire
COMPANY_EMAIL=contact@sgfire.com
COMPANY_PHONE=+91-9876543210
COMPANY_ADDRESS=Mumbai, Maharashtra, India

# ─────────────────────────────────────────────
# ADMIN CREDENTIALS (for development/seed)
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@sgfire.com
ADMIN_PASSWORD=adminpassword123
