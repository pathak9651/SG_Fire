# =============================================================
# SG Fire — .gitignore
# Prevents sensitive and generated files from being committed
# =============================================================

# ── Environment Files ─────────────────────────────────────
# NEVER commit .env files — they contain secrets!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Node Modules ──────────────────────────────────────────
# Installed via npm install — always regeneratable
node_modules/
*/node_modules/

# ── Next.js Build Output ──────────────────────────────────
frontend/.next/
frontend/out/

# ── Build Artifacts ────────────────────────────────────────
dist/
build/

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ── Upload Temp Directory ──────────────────────────────────
backend/uploads/

# ── IDE/Editor Files ──────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
